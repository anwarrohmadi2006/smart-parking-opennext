{
  "rules": {
    ".read": true,
    
    "slots": {
      ".write": true,
      "$slotId": {
        "status": {
          ".validate": "newData.val() == 'kosong' || newData.val() == 'terisi'"
        },
        "id": {
          ".validate": "newData.val() == $slotId"
        }
      }
    },
    
    "config": {
      ".write": true,
      "harga_per_jam": {
        ".validate": "newData.isNumber() && newData.val() > 0"
      },
      "demo_mode": {
        ".validate": "newData.isBoolean()"
      }
    },
    
    "activeVehicles": {
      ".write": true,
      "$ticketId": {
        "ticketId": {
          ".validate": "newData.val() == $ticketId"
        },
        "slotId": {
          ".validate": "newData.isString()"
        },
        "checkInTime": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    
    "logs": {
      ".write": true,
      "$logId": {
        "id": {
          ".validate": "newData.val() == $logId"
        },
        "type": {
          ".validate": "newData.val() == 'in' || newData.val() == 'out'"
        },
        "timestamp": {
          ".validate": "newData.isNumber()"
        }
      }
    }
  }
}
